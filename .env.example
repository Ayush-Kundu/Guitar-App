# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
# Optional: exact OAuth return URL (must match Supabase → Auth → Redirect URLs, character-for-character).
# Local (Vite default port): use trailing slash. Leave unset to use window.location.origin + "/" instead.
# VITE_AUTH_REDIRECT_URL=http://localhost:3001/
# Production deploy example (uncomment and adjust when you ship):
# VITE_AUTH_REDIRECT_URL=https://strummy.studio/

# Comma-separated extra blocked phrases (case-insensitive) for community + DMs
# VITE_MODERATION_EXTRA_TERMS=phrase one,other phrase
DATABASE_URL=postgresql://postgres:your-password@db.your-project.supabase.co:5432/postgres

# Google Gemini API Key (free tier - get one at https://aistudio.google.com/apikey)
VITE_GEMINI_API_KEY=your-gemini-key-here

# OTA (Over-The-Air) update manifest URL for the iOS app.
# The app checks this on launch for a newer web asset bundle.
# See scripts/prepare-ota.sh for how to create and upload bundles.
# VITE_OTA_UPDATE_URL=https://strummy.studio/ota/manifest.json

# Google Sign-In (native iOS). Create OAuth clients at https://console.cloud.google.com/apis/credentials:
#  - Web client (same one configured in Supabase → Auth → Google as the primary Client ID)
#  - iOS client with bundle id `com.strummyak.app`
# Add the iOS client ID to Supabase → Auth → Google as an "Additional Authorized Client ID" so
# Supabase will accept id_tokens whose `aud` claim matches the iOS client.
# VITE_GOOGLE_WEB_CLIENT_ID=1234567890-abc.apps.googleusercontent.com
# VITE_GOOGLE_IOS_CLIENT_ID=1234567890-xyz.apps.googleusercontent.com
