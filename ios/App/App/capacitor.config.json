{
	"appId": "com.strummyak.app",
	"appName": "Strummy",
	"webDir": "build",
	"ios": {
		"contentInset": "never",
		"preferredContentMode": "mobile",
		"scheme": "Strummy",
		"allowsLinkPreview": false,
		"scrollEnabled": false
	},
	"plugins": {
		"StatusBar": {
			"style": "dark",
			"overlaysWebView": true
		},
		"CapacitorHttp": {
			"enabled": true
		},
		"CapacitorUpdater": {
			"autoUpdate": false
		}
	},
	"server": {
		"cleartext": true
	},
	"packageClassList": [
		"AppPlugin",
		"CAPBrowserPlugin",
		"FilesystemPlugin",
		"HapticsPlugin",
		"LocalNotificationsPlugin",
		"PreferencesPlugin",
		"ScreenOrientationPlugin",
		"StatusBarPlugin",
		"SocialLoginPlugin",
		"CapacitorUpdaterPlugin",
		"InAppBrowserPlugin"
	]
}
